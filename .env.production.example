# =============================================================================
# SubAlchemy - .env.production (EXAMPLE FOR COMMIT)
# =============================================================================
# Instructions: Copy this file to `.env.production` and fill in your own values.
# NEVER commit the actual `.env.production` file.
#
# To generate a secure ENCRYPTION_KEY:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

# ---- Network / Port ---------------------------------------------------------
# Port that Express will listen to INSIDE the container.
PORT=10000

# URL of the addon.
# IMPORTANT: For local development, keep this as http://localhost:10000
# For production, replace it with your actual HTTPS URL (e.g., https://yourdomain.com)
BASE_URL=http://localhost:10000

# ---- Logging ----------------------------------------------------------------
# Levels: error | warn | info | debug
LOG_LEVEL=info

# ---- OpenSubtitles v2 fallback (optional) -----------------------------------
# Used ONLY when the legacy REST API fails.
# Leave empty for local testing; fill in if you plan to use it in production.
OS_API_KEY=

# ---- Pre-filled keys in the UI (optional) -----------------------------------
# All empty by default. The user will fill these with their own keys.
SUBDL_API_KEY=
SUBSOURCE_API_KEY=
WYZIE_API_KEY=

# ---- Config encryption in the install URL (recommended for production) ------
# Generate with the command above. Leave empty for local development
# (the system will fall back to unencrypted base64-JSON).
ENCRYPTION_KEY=

# ---- Provider tuning (optional) ---------------------------------------------
PROVIDER_DEADLINE_MS=10000

# ---- WARP Proxy (DO NOT CHANGE) ---------------------------------------------
# The WARP proxy is hardcoded in src/providers/OpenSubtitlesProvider.js and
# src/converters/index.js as socks5://127.0.0.1:40000 (socks-proxy-agent).
# There is NO reading of HTTP_PROXY/HTTPS_PROXY/NO_PROXY by the code.
# If you want to route ALL outgoing traffic through WARP, install the
# "global-agent" package and set GLOBAL_AGENT_HTTP_PROXY=socks5://127.0.0.1:40000.
# ATTENTION: this may break SubDL/SubSource/Wyzie if they block Cloudflare IPs.
# Recommendation: keep the current design (only OpenSubtitles via WARP).